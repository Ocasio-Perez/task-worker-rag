# Copy these values into the Hermes gateway EnvironmentFile.
# Common path: ~/.config/systemd/user/hermes-gateway.env

CODE_SEARCH_URL=http://127.0.0.1:9000/api/search-codebase
CODE_READ_FILE_URL=http://127.0.0.1:9000/api/read-file
CODE_SEARCH_HMAC_SECRET=replace-with-the-same-secret-as-task-worker

# Enable temporarily when debugging Hermes plugin argument shapes.
TASK_WORKER_CODE_TOOLS_DEBUG=0
