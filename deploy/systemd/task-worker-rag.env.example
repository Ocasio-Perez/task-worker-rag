# Copy to ~/.config/systemd/user/task-worker-rag.env and edit secrets.

HOST=127.0.0.1
PORT=9000
AGENT_NAME=task-worker-rag

REPO_ROOT=/home/larry/.hermes/repos
CHROMA_URL=http://127.0.0.1:8000
CHROMA_COLLECTION=codebase

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

CODE_SEARCH_HMAC_SECRET=replace-with-a-long-random-secret
CODE_SEARCH_URL=http://127.0.0.1:9000/api/search-codebase
CODE_READ_FILE_URL=http://127.0.0.1:9000/api/read-file
TASK_WORKER_URL=http://127.0.0.1:9000

HERMES_SECRET=replace-with-hermes-task-secret
OPENCLAW_SECRET=replace-with-openclaw-secret
HERMES_WEBHOOK_URL=http://127.0.0.1:8644/webhook/task-worker-result
OPENCLAW_URL=http://127.0.0.1:18789/task
